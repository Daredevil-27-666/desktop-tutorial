# Anthropic API key — used by Claude Code to talk to Claude.
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram bot token — create a bot with @BotFather on Telegram and paste
# the token here. NEVER commit the filled-in .env file.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram numeric user IDs allowed to talk to
# the bot. Anyone not on this list is silently ignored. Get your ID from
# @userinfobot on Telegram.
#
# The default below is the owner of this repo. If you fork this, REPLACE
# IT with your own ID, or the owner will be able to talk to your bot.
TELEGRAM_ALLOWED_USER_IDS=6825790063

# Working directory for Claude Code. The bot spawns `claude` with this as
# its cwd, so any files it reads/writes end up here.
WORK_DIR=/home/jarvis/workspace

# Path to the `claude` binary. Leave as `claude` if it's on PATH.
CLAUDE_BIN=claude
